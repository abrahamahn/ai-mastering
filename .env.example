# Safe template for local Windows rendering settings. Put real values in .env.local.

WINDOWS_PYTHON=python.exe

# Optional. The scripts also forward OPENAI_API_KEY from your shell if set.
OPENAI_API_KEY=

# Local model scoring for ai-render. Set to 0 to force metric-only scoring.
MASTERING_LOCAL_MODELS=1
MASTERING_LOCAL_MODELS_OFFLINE=0
MASTERING_MODEL_DEVICE=auto
MASTERING_CLAP=1
MASTERING_CLAP_MODEL=laion/larger_clap_music
MASTERING_MERT=1
MASTERING_MERT_MODEL=m-a-p/MERT-v1-95M
MASTERING_REFERENCE_DIR=
